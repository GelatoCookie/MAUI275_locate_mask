<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiRfidSample.MVVM.Views.Gen2XTagProtection"
   xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:local="clr-namespace:MauiRfidSample.MVVM.ViewModels">

        <Shell.TitleView>
            <Grid Padding="0" ColumnSpacing="8"
          ColumnDefinitions="*,Auto"
          VerticalOptions="Center"
          HorizontalOptions="FillAndExpand">
                <Label Text="Gen2X Tag Protection"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Start"
               VerticalOptions="Center" />
                <Button Grid.Column="1"
                Text="ⓘ"
                Clicked="InfoItemClicked"
                FontSize="28"
                BackgroundColor="Transparent"
                TextColor="Black"
                Padding="0"
                HeightRequest="40"
                WidthRequest="40" />
            </Grid>
        </Shell.TitleView>

        <StackLayout Padding="0">
            
            <ScrollView
                x:Name="readWriteView"
                Padding="10,10,10,10"
                IsVisible="true">
                <StackLayout Padding="5" Orientation="Vertical">
                    <Entry
                        x:Name="tagPattern"
                        Placeholder="Tag Pattern"
                        Text="{Binding TagPattern, Mode=TwoWay}" />
                    
                    <StackLayout Orientation="Horizontal" Spacing="15">
                        <Label Text="Operation" VerticalTextAlignment="Center" />
                        <Picker
                            x:Name="oppicker"
                            HorizontalOptions="FillAndExpand"
                            SelectedItem="{Binding OpMode, Mode=TwoWay}">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Protect</x:String>
                                    <x:String>Unprotect</x:String>
                                    <x:String>GetPassword</x:String>
                                    <x:String>SetPassword</x:String>
                                    <x:String>Enable Inventory Of Protected Tags</x:String>
                                    <x:String>Clear Protected Mode Configuration</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                            <Picker.SelectedIndex>0</Picker.SelectedIndex>
                        </Picker>
                    </StackLayout>
                    <StackLayout Orientation="Vertical" VerticalOptions="EndAndExpand">
                        <Label Text="Pin/Password"/>
                         <Editor
                            x:Name="data"
                            AutoSize="TextChanges"
                            HorizontalOptions="FillAndExpand"
                            Text="{Binding AccessPW, Mode=TwoWay}" /> 
                    </StackLayout>
                    <StackLayout
                            HorizontalOptions="CenterAndExpand"
                            Orientation="Horizontal"
                            VerticalOptions="EndAndExpand">
                            <Button
                                BackgroundColor="Blue"
                                Clicked="PerformOperation"
                                HorizontalOptions="FillAndExpand"
                                Text="Perform Operation"
                                TextColor="White" />
                            <Button
                                BackgroundColor="Blue"
                                Clicked="DeleteAll"
                                HorizontalOptions="FillAndExpand"
                                Text="DeleteAll-Prefilters"
                                TextColor="White" />
                    </StackLayout>
                </StackLayout>

            </ScrollView>

            
        </StackLayout>

</ContentPage>